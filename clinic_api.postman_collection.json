{
  "info": {
    "name": "Clinic Management System API",
    "_postman_id": "clinic-mgmt-collection",
    "description": "All API endpoints for the Clinic Management System. Base URL: http://localhost:8000\n\n**Flow:**\n1. Run a Login request → copy the `access_token`\n2. In the collection Variables tab, paste it as the value of `token`\n3. All protected requests use {{token}} automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token",    "value": "<paste_token_here>" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/signup", "host": ["{{base_url}}"], "path": ["signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@clinic.com\",\n  \"password\": \"1234567p\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login – Admin",
